{
	"name": "eslint-rule-tester",
	"version": "11.0.0",
	"description": "A command-line interface for running ESLint rule unit tests",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ThisIsManta/eslint-rule-tester.git"
	},
	"type": "module",
	"bin": "exec.js",
	"main": "main.js",
	"types": "main.d.ts",
	"files": [
		"exec.js",
		"main.js",
		"main.d.ts",
		"format.js"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsc",
		"test": "vitest --exclude=__fixures__",
		"version": "npm run build",
		"postversion": "npm publish --provenance --access public"
	},
	"keywords": [
		"eslint"
	],
	"author": "thisismanta@gmail.com",
	"license": "MIT",
	"peerDependencies": {
		"eslint": ">=10.0.0"
	},
	"devDependencies": {
		"@thisismanta/semantic-version": "^11.2.0",
		"@types/node": "^20.19.39",
		"eslint": "^10.2.0",
		"lefthook": "^2.1.5",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@thisismanta/pessimist": "^3.1.1",
		"chalk": "^5.6.2",
		"glob": "^13.0.6"
	}
}
