{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": false,
    "lib": [
      "esnext"
    ],
    "module": "node20",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "noUncheckedSideEffectImports": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2020",
    "types": [
      "node"
    ],
    "verbatimModuleSyntax": true,
  }
}